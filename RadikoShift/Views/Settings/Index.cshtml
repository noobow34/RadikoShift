@model RadikoShift.ViewModel.SettingsViewModel
@{
    ViewData["Title"] = "設定";
}

<h2 class="mb-4">設定</h2>

<div class="row g-4">
    @* 手動実行カード *@
    <div class="col-12 col-md-6">
        <div class="card h-100">
            <div class="card-header fw-bold">番組表の手動更新</div>
            <div class="card-body d-flex flex-column justify-content-between">
                <p class="text-muted small mb-3">
                    今すぐ番組表を取得・更新します。通常は定期実行されますが、すぐに最新の番組情報が必要な場合にご利用ください。
                </p>
                <button type="button" class="btn btn-primary w-100" id="btnRunNow">
                    今すぐ実行
                </button>
            </div>
        </div>
    </div>

    @* スケジュール・並列数設定カード *@
    <div class="col-12 col-md-6">
        <div class="card h-100">
            <div class="card-header fw-bold">定期実行の設定</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">番組表更新時刻</label>
                    <div class="d-flex align-items-center gap-2">
                        <input type="number" class="form-control text-center"
                               id="refreshHour" value="@Model.RefreshHour"
                               min="0" max="23" style="width:80px" />
                        <span>時</span>
                        <input type="number" class="form-control text-center"
                               id="refreshMinute" value="@Model.RefreshMinute"
                               min="0" max="59" style="width:80px" />
                        <span>分</span>
                    </div>
                    <div class="form-text">毎日この時刻に番組表を自動更新します（デフォルト: 6:00）</div>
                </div>
                <div class="mb-4">
                    <label class="form-label">番組表取得の並列数</label>
                    <div class="d-flex align-items-center gap-2">
                        <input type="number" class="form-control text-center"
                               id="parallelCount" value="@Model.ParallelCount"
                               min="1" max="50" style="width:80px" />
                        <span>並列</span>
                    </div>
                    <div class="form-text">放送局ごとの番組取得を何並列で行うか設定します（デフォルト: 10）</div>
                </div>
                <button type="button" class="btn btn-success w-100" id="btnSave">保存</button>
            </div>
        </div>
    </div>
</div>

<!-- Toast -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="appToast" class="toast text-bg-success border-0">
        <div class="toast-body"></div>
    </div>
</div>

@section Scripts {
<script>
    function showToast(message, type) {
        const toastEl = document.getElementById('appToast');
        toastEl.classList.remove('text-bg-success', 'text-bg-danger');
        toastEl.classList.add(`text-bg-${type}`);
        toastEl.querySelector('.toast-body').textContent = message;
        new bootstrap.Toast(toastEl, { delay: 2000 }).show();
    }

    // 今すぐ実行
    document.getElementById('btnRunNow').addEventListener('click', function () {
        const btn = this;
        btn.disabled = true;
        btn.textContent = '実行中...';

        $.post('/Settings/RunNow')
            .done(function (res) {
                showToast(res.message, 'success');
            })
            .fail(function () {
                showToast('エラーが発生しました。', 'danger');
            })
            .always(function () {
                btn.disabled = false;
                btn.textContent = '今すぐ実行';
            });
    });

    // 設定保存
    document.getElementById('btnSave').addEventListener('click', function () {
        const btn = this;
        btn.disabled = true;
        btn.textContent = '保存中...';

        $.post('/Settings/Save', {
            refreshHour:   $('#refreshHour').val(),
            refreshMinute: $('#refreshMinute').val(),
            parallelCount: $('#parallelCount').val()
        })
            .done(function (res) {
                showToast(res.message, 'success');
            })
            .fail(function () {
                showToast('エラーが発生しました。', 'danger');
            })
            .always(function () {
                btn.disabled = false;
                btn.textContent = '保存';
            });
    });
</script>
}
