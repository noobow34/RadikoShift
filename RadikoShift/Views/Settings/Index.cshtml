@model RadikoShift.ViewModel.SettingsViewModel
@{
    ViewData["Title"] = "設定";
}

<h2 class="mb-4">設定</h2>

<div class="row g-4">
    @* 手動実行カード *@
    <div class="col-12 col-md-6">
        <div class="card h-100" id="runNowCard">
            <div class="card-header fw-bold" id="runNowCardHeader">番組表の手動更新</div>
            <div class="card-body d-flex flex-column justify-content-between">
                <p class="small mb-3" id="runNowCardDesc">
                    今すぐ番組表を取得・更新します。通常は定期実行されますが、すぐに最新の番組情報が必要な場合にご利用ください。
                </p>
                @* 直近実行サマリー *@
                <div id="lastRunSummary" class="mb-3 p-2 rounded border small d-none">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <span id="summaryBadge" class="badge"></span>
                        <span class="text-muted">開始: <span id="summaryStartedAt"></span></span>
                        <span class="text-muted">終了: <span id="summaryFinishedAt"></span></span>
                        <span class="text-muted">所要: <span id="summaryElapsed"></span></span>
                    </div>
                </div>
                <div id="lastRunNone" class="mb-3 text-muted small d-none">実行履歴なし</div>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-primary w-50" id="btnRunNow">今すぐ実行</button>
                    <button type="button" class="btn btn-outline-secondary w-50" id="btnShowLog">ログを見る</button>
                </div>
            </div>
        </div>
    </div>

    @* スケジュール・並列数設定カード *@
    <div class="col-12 col-md-6">
        <div class="card h-100">
            <div class="card-header fw-bold">定期実行の設定</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">番組表更新時刻</label>
                    <div class="d-flex align-items-center gap-2">
                        <input type="number" class="form-control text-center"
                               id="refreshHour" value="@Model.RefreshHour"
                               min="@Model.MinRefreshHour" max="@Model.MaxRefreshHour" style="width:80px" />
                        <span>時</span>
                        <input type="number" class="form-control text-center"
                               id="refreshMinute" value="@Model.RefreshMinute"
                               min="@Model.MinRefreshMinute" max="@Model.MaxRefreshMinute" style="width:80px" />
                        <span>分</span>
                    </div>
                    <div class="form-text">毎日この時刻に番組表を自動更新します（デフォルト: @Model.DefaultRefreshHour:@Model.DefaultRefreshMinute.ToString("D2")）</div>
                </div>
                <div class="mb-4">
                    <label class="form-label">番組表取得の並列数</label>
                    <div class="d-flex align-items-center gap-2">
                        <input type="number" class="form-control text-center"
                               id="parallelCount" value="@Model.ParallelCount"
                               min="@Model.MinParallelCount" max="@Model.MaxParallelCount" style="width:80px" />
                        <span>並列</span>
                    </div>
                    <div class="form-text">放送局ごとの番組取得を何並列で行うか設定します（デフォルト: @Model.DefaultParallelCount）</div>
                </div>
                <button type="button" class="btn btn-success w-100" id="btnSave">保存</button>
            </div>
        </div>
    </div>
</div>

<!-- 実行ログ モーダル -->
<div class="modal fade" id="logModal" tabindex="-1" aria-labelledby="logModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="logModalLabel">番組表更新 直近実行ログ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="閉じる"></button>
            </div>
            <div class="modal-body">
                <!-- サマリー -->
                <div id="logSummary" class="mb-3 d-none">
                    <div class="d-flex gap-3 align-items-center flex-wrap">
                        <span id="logBadge" class="badge fs-6"></span>
                        <small class="text-muted">開始: <span id="logStartedAt"></span></small>
                        <small class="text-muted">終了: <span id="logFinishedAt"></span></small>
                        <small class="text-muted">所要: <span id="logElapsed"></span></small>
                    </div>
                </div>
                <!-- ログ本文 -->
                <pre id="logContent"
                     class="bg-dark text-light rounded p-3 small"
                     style="max-height:460px; overflow-y:auto; white-space:pre-wrap; word-break:break-all;">
                </pre>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">閉じる</button>
            </div>
        </div>
    </div>
</div>

<!-- Toast -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="appToast" class="toast text-bg-success border-0">
        <div class="toast-body"></div>
    </div>
</div>

@section Scripts {
<script>
    function showToast(message, type) {
        const toastEl = document.getElementById('appToast');
        toastEl.classList.remove('text-bg-success', 'text-bg-danger');
        toastEl.classList.add(`text-bg-${type}`);
        toastEl.querySelector('.toast-body').textContent = message;
        new bootstrap.Toast(toastEl, { delay: 2000 }).show();
    }

    // サマリーをカードに反映する共通関数
    function applyLogSummary(res) {
        const summaryEl = document.getElementById('lastRunSummary');
        const noneEl    = document.getElementById('lastRunNone');
        if (!res.exists) {
            summaryEl.classList.add('d-none');
            noneEl.classList.remove('d-none');
            return;
        }
        const badge = document.getElementById('summaryBadge');
        if (res.isRunning) {
            badge.textContent = '実行中...';
            badge.className   = 'badge bg-warning text-dark';
        } else {
            badge.textContent = res.succeeded ? '成功' : '失敗';
            badge.className   = 'badge ' + (res.succeeded ? 'bg-success' : 'bg-danger');
        }
        document.getElementById('summaryStartedAt').textContent  = res.startedAt;
        document.getElementById('summaryFinishedAt').textContent = res.isRunning ? '—' : res.finishedAt;
        document.getElementById('summaryElapsed').textContent    = res.isRunning ? '—' : res.elapsed;
        noneEl.classList.add('d-none');
        summaryEl.classList.remove('d-none');
    }

    // ページロード時にサマリー取得（実行中ならそのままポーリング開始）
    $.get('/Settings/GetLastRefreshLog').done(function (res) {
        applyLogSummary(res);
        if (res.exists && res.isRunning) startPolling();
    });

    // ポーリング設定
    const POLL_INTERVAL_MS = 3000;
    const POLL_TIMEOUT_MS  = 5 * 60 * 1000; // 5分
    let pollTimer    = null;
    let pollDeadline = null;

    function setCardRunning(running) {
        const card       = document.getElementById('runNowCard');
        const header     = document.getElementById('runNowCardHeader');
        const desc       = document.getElementById('runNowCardDesc');
        if (running) {
            card.classList.add('border-warning');
            header.classList.add('bg-warning', 'bg-opacity-25');
            desc.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status"></span>番組表を更新しています。しばらくお待ちください...';
            desc.classList.remove('text-muted');
        } else {
            card.classList.remove('border-warning');
            header.classList.remove('bg-warning', 'bg-opacity-25');
            desc.textContent = '今すぐ番組表を取得・更新します。通常は定期実行されますが、すぐに最新の番組情報が必要な場合にご利用ください。';
            desc.classList.add('text-muted');
        }
    }

    function startPolling() {
        if (pollTimer) return; // 二重起動防止
        setCardRunning(true);
        pollDeadline = Date.now() + POLL_TIMEOUT_MS;
        pollTimer = setInterval(async function () {
            if (Date.now() > pollDeadline) {
                stopPolling();
                showToast('実行完了を確認できませんでした（タイムアウト）。', 'danger');
                return;
            }
            $.get('/Settings/GetLastRefreshLog').done(function (res) {
                if (!res.exists || res.isRunning) return; // まだ実行中
                stopPolling();
                applyLogSummary(res);
                showToast(res.succeeded ? '番組表更新が完了しました。' : '番組表更新が失敗しました。', res.succeeded ? 'success' : 'danger');
            });
        }, POLL_INTERVAL_MS);
    }

    function stopPolling() {
        if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
        setCardRunning(false);
    }

    // 今すぐ実行
    document.getElementById('btnRunNow').addEventListener('click', function () {
        const btn = this;
        btn.disabled = true;
        btn.textContent = '実行中...';

        $.post('/Settings/RunNow')
            .done(function (res) {
                showToast(res.message, 'success');
                startPolling();
            })
            .fail(function () {
                showToast('エラーが発生しました。', 'danger');
                btn.disabled = false;
                btn.textContent = '今すぐ実行';
            });

        // ポーリング完了 or タイムアウト後にボタンを戻す
        const restoreBtn = setInterval(function () {
            if (!pollTimer) {
                btn.disabled = false;
                btn.textContent = '今すぐ実行';
                clearInterval(restoreBtn);
            }
        }, 500);
    });

    // 設定保存
    document.getElementById('btnSave').addEventListener('click', function () {
        const btn = this;
        btn.disabled = true;
        btn.textContent = '保存中...';

        $.post('/Settings/Save', {
            refreshHour:   $('#refreshHour').val(),
            refreshMinute: $('#refreshMinute').val(),
            parallelCount: $('#parallelCount').val()
        })
            .done(function (res) {
                showToast(res.message, 'success');
            })
            .fail(function () {
                showToast('エラーが発生しました。', 'danger');
            })
            .always(function () {
                btn.disabled = false;
                btn.textContent = '保存';
            });
    });

    // ログ表示
    document.getElementById('btnShowLog').addEventListener('click', function () {
        const logContent = document.getElementById('logContent');
        const logSummary = document.getElementById('logSummary');
        logContent.textContent = '読み込み中...';
        logSummary.classList.add('d-none');

        $.get('/Settings/GetLastRefreshLog')
            .done(function (res) {
                if (!res.exists) {
                    logContent.textContent = '実行履歴がありません。';
                } else {
                    const badge = document.getElementById('logBadge');
                    badge.textContent  = res.succeeded ? '成功' : '失敗';
                    badge.className    = 'badge fs-6 ' + (res.succeeded ? 'bg-success' : 'bg-danger');
                    document.getElementById('logStartedAt').textContent  = res.startedAt;
                    document.getElementById('logFinishedAt').textContent = res.finishedAt;
                    document.getElementById('logElapsed').textContent    = res.elapsed;
                    logSummary.classList.remove('d-none');
                    logContent.textContent = res.lines.join('\n');
                    logContent.scrollTop = logContent.scrollHeight;
                }
            })
            .fail(function () {
                logContent.textContent = 'ログの取得に失敗しました。';
            });

        new bootstrap.Modal(document.getElementById('logModal')).show();
    });
</script>
}
